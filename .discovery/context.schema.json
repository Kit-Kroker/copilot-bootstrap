{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "context.schema.json",
  "title": "Discovery Context",
  "description": "Unified tech stack and project context. Single structured input for all generators and pipeline steps.",
  "type": "object",
  "required": ["stack", "tools", "arch", "paths"],
  "properties": {
    "stack": {
      "type": "object",
      "description": "Programming languages and frameworks detected in the project",
      "required": ["languages"],
      "properties": {
        "languages": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "description": "Primary programming languages (e.g. [\"typescript\", \"python\"])"
        },
        "frontend": {
          "type": ["string", "null"],
          "description": "Frontend framework (e.g. \"react\", \"vue\", \"angular\", null)"
        },
        "backend": {
          "type": ["string", "null"],
          "description": "Backend runtime or framework (e.g. \"node\", \"fastapi\", \"django\", null)"
        },
        "db": {
          "type": ["string", "null"],
          "description": "Primary database (e.g. \"postgres\", \"mysql\", \"mongodb\", null)"
        }
      },
      "additionalProperties": false
    },
    "tools": {
      "type": "object",
      "description": "Detected toolchain",
      "properties": {
        "package_managers": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/tool" },
          "description": "All detected package managers, one per language ecosystem (e.g. [{\"name\":\"npm\",\"version\":\"10.2.4\"},{\"name\":\"uv\",\"version\":\"0.5.1\"}])"
        },
        "linters": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/tool" },
          "description": "All detected linters, one per ecosystem (e.g. [{\"name\":\"eslint\",\"version\":\"9.0.0\"},{\"name\":\"ruff\",\"version\":\"0.4.0\"}])"
        },
        "formatters": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/tool" },
          "description": "All detected formatters, one per ecosystem (e.g. [{\"name\":\"prettier\",\"version\":\"3.0.0\"},{\"name\":\"black\",\"version\":\"24.0.0\"}])"
        },
        "test_runners": {
          "type": ["array", "null"],
          "items": { "$ref": "#/$defs/tool" },
          "description": "All detected test runners, one per ecosystem (e.g. [{\"name\":\"vitest\",\"version\":\"1.6.0\"},{\"name\":\"pytest\",\"version\":\"8.0.0\"}])"
        },
        "bundler": {
          "oneOf": [{ "$ref": "#/$defs/tool" }, { "type": "null" }],
          "description": "Detected frontend bundler (e.g. {\"name\":\"vite\",\"version\":\"5.0.0\"})"
        },
        "container": {
          "type": ["string", "null"],
          "description": "e.g. \"docker\", \"podman\""
        }
      },
      "additionalProperties": false
    },
    "arch": {
      "type": "object",
      "description": "Detected architecture style",
      "required": ["style", "monorepo", "services"],
      "properties": {
        "style": {
          "type": "string",
          "enum": ["layered", "hexagonal", "microservices", "monolith", "monorepo", "serverless", "unknown"],
          "description": "High-level architecture pattern"
        },
        "monorepo": {
          "type": "boolean",
          "description": "True if multiple packages/apps live in a single repo"
        },
        "services": {
          "type": "integer",
          "minimum": 1,
          "description": "Number of distinct services (1 for monolith)"
        }
      },
      "additionalProperties": false
    },
    "paths": {
      "type": "object",
      "description": "Key directory paths relative to project root",
      "required": ["src", "tests", "docs", "config"],
      "properties": {
        "src": { "type": "string" },
        "tests": { "type": "string" },
        "docs": { "type": "string" },
        "config": { "type": "string" }
      },
      "additionalProperties": false
    },
    "entrypoints": {
      "type": "array",
      "description": "Detected application entrypoints",
      "items": {
        "type": "object",
        "required": ["type", "path"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["http", "cli", "worker", "cron", "grpc"],
            "description": "Entrypoint kind"
          },
          "path": {
            "type": "string",
            "description": "Path relative to project root"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "tool": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name":    { "type": "string" },
        "version": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    }
  },
  "examples": [
    {
      "stack": {
        "languages": ["typescript"],
        "frontend": "react",
        "backend": "node",
        "db": "postgres"
      },
      "tools": {
        "package_managers": [{"name": "npm", "version": "10.2.4"}],
        "linters":          [{"name": "eslint", "version": "9.0.0"}],
        "formatters":       [{"name": "prettier", "version": "3.0.0"}],
        "test_runners":     [{"name": "jest", "version": "29.0.0"}],
        "bundler":          {"name": "vite", "version": "5.0.0"},
        "container":        "docker"
      },
      "arch": {
        "style": "layered",
        "monorepo": false,
        "services": 1
      },
      "paths": {
        "src": "src/",
        "tests": "tests/",
        "docs": "docs/",
        "config": "."
      },
      "entrypoints": [
        { "type": "http", "path": "src/server.ts" },
        { "type": "cli", "path": "src/cli.ts" }
      ]
    }
  ]
}
