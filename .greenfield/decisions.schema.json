{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "decisions.schema.json",
  "title": "Greenfield Technology Decisions",
  "description": "Technology and architecture decisions with rationale. Captures what was chosen, why, and which fields were defaulted. Input for instructions and configuration generators.",
  "type": "object",
  "required": ["stack_rationale", "tools_rationale", "arch_rationale", "defaults_applied"],
  "properties": {
    "stack_rationale": {
      "type": "object",
      "description": "Rationale for technology stack choices",
      "properties": {
        "language": { "$ref": "#/definitions/decision_entry" },
        "frontend": { "$ref": "#/definitions/decision_entry" },
        "backend": { "$ref": "#/definitions/decision_entry" },
        "db": { "$ref": "#/definitions/decision_entry" },
        "runtime": { "$ref": "#/definitions/decision_entry" }
      },
      "additionalProperties": false
    },
    "tools_rationale": {
      "type": "object",
      "description": "Rationale for toolchain choices (user-chosen vs smart defaults)",
      "properties": {
        "package_manager": { "$ref": "#/definitions/decision_entry" },
        "linter": { "$ref": "#/definitions/decision_entry" },
        "formatter": { "$ref": "#/definitions/decision_entry" },
        "test_runner": { "$ref": "#/definitions/decision_entry" },
        "bundler": { "$ref": "#/definitions/decision_entry" },
        "container": { "$ref": "#/definitions/decision_entry" },
        "orchestrator": { "$ref": "#/definitions/decision_entry" }
      },
      "additionalProperties": false
    },
    "arch_rationale": {
      "type": "object",
      "description": "Rationale for architecture decisions",
      "properties": {
        "style": { "$ref": "#/definitions/decision_entry" },
        "auth": { "$ref": "#/definitions/decision_entry" },
        "monorepo": { "$ref": "#/definitions/decision_entry" }
      },
      "additionalProperties": false
    },
    "defaults_applied": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Fields where smart defaults were applied (user did not explicitly choose). Used by instructions generator to explain toolchain choices."
    }
  },
  "definitions": {
    "decision_entry": {
      "type": "object",
      "required": ["choice", "source", "reason"],
      "properties": {
        "choice": { "description": "The value chosen (string or boolean)" },
        "source": {
          "type": "string",
          "enum": ["user", "default", "derived"],
          "description": "How the value was obtained: user=explicit answer, default=smart default applied, derived=computed from another answer"
        },
        "reason": { "type": "string", "description": "Why this choice was made or how it was derived" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false,
  "examples": [
    {
      "stack_rationale": {
        "language": { "choice": "typescript", "source": "user", "reason": "User selected" },
        "frontend": { "choice": "react", "source": "user", "reason": "User selected" },
        "backend": { "choice": "node", "source": "user", "reason": "User selected" },
        "db": { "choice": "postgres", "source": "user", "reason": "User selected" },
        "runtime": { "choice": "node", "source": "derived", "reason": "Derived from language: typescript" }
      },
      "tools_rationale": {
        "package_manager": { "choice": "npm", "source": "default", "reason": "Default for TypeScript" },
        "linter": { "choice": "eslint", "source": "default", "reason": "Default for TypeScript" },
        "formatter": { "choice": "prettier", "source": "default", "reason": "Default for TypeScript" },
        "test_runner": { "choice": "vitest", "source": "default", "reason": "Default for React + Vite" },
        "bundler": { "choice": "vite", "source": "default", "reason": "Default for React" }
      },
      "arch_rationale": {
        "style": { "choice": "layered", "source": "derived", "reason": "Single service, web app" },
        "monorepo": { "choice": false, "source": "derived", "reason": "Single service project" }
      },
      "defaults_applied": ["package_manager", "linter", "formatter", "test_runner", "bundler", "runtime"]
    }
  ]
}
